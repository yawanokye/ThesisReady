# Core application
APP_NAME=ProjectReady AI
APP_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=32000
OPENAI_MAX_OUTPUT_TOKENS_HARD_CAP=64000
OPENAI_SAFE_RETRY_MAX_OUTPUT_TOKENS=12000
PROJECTREADY_WORDS_PER_PAGE=330
PROJECTREADY_CHUNKED_GENERATION_THRESHOLD_WORDS=9000
PROJECTREADY_CHUNK_TARGET_WORDS=8000
PROJECTREADY_MAX_CHAPTER_CHUNKS=4
PROJECTREADY_DEPTH_ACCEPTANCE_RATIO=0.90
PROJECTREADY_LONG_CHAPTER_REVISION_LIMIT_WORDS=12000

# Database storage
# Local development: leave DATABASE_URL blank and use the SQLite paths below.
# Render single-instance deployment: mount a persistent disk at /var/data and set
# DATABASE_URL=/var/data/projectready.db. Both project and payment records will
# use that durable file. PostgreSQL is recommended when scaling to many instances.
DATABASE_URL=
PROJECTREADY_SQLITE_DB_PATH=projectready.db
PROJECTREADY_SQLITE_PAYMENT_DB=projectready.db

# Payment redirects
PROJECTREADY_PAYMENT_SUCCESS_PATH=/workspace
PROJECTREADY_PAYMENT_CANCEL_PATH=/workspace

# Paystack for African billing countries
PAYSTACK_SECRET_KEY=sk_test_replace_me
PROJECTREADY_PAYSTACK_BACHELORS_GHS=
PROJECTREADY_PAYSTACK_MASTERS_GHS=
PROJECTREADY_PAYSTACK_DOCTORATE_GHS=
PROJECTREADY_PAYSTACK_USD_TO_GHS_RATE=15.00
PAYSTACK_USER_AGENT=ProjectReadyAI/1.0 (+https://projectreadyai.com; payments@projectreadyai.com)

# Stripe for non-African billing countries
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Topic-idea data and instrument discovery
TOPIC_RESOURCE_SEARCH_TIMEOUT_SECONDS=10
TOPIC_DATASET_RESULTS=8
TOPIC_INSTRUMENT_RESULTS=8


# Integrated Chapter Strengthener
PROJECTREADY_CHAPTER_REVISION_USE_AI=1
PROJECTREADY_CHAPTER_REVISION_TIMEOUT_SECONDS=240
PROJECTREADY_CHAPTER_REVISION_MAX_OUTPUT_TOKENS=30000
OPENAI_CHAPTER_REVISION_MODEL=gpt-5.5
OPENAI_CHAPTER_REVISION_BACHELOR_MODEL=gpt-5.4
OPENAI_CHAPTER_REVISION_MASTERS_MODEL=gpt-5.4
OPENAI_CHAPTER_REVISION_RESEARCH_MODEL=gpt-5.5
OPENAI_CHAPTER_REVISION_DOCTORAL_MODEL=gpt-5.5
PROJECTREADY_MAX_UPLOAD_BYTES=15728640
PROJECTREADY_MAX_EXTRACTED_CHARS=120000

# Project ID recovery, no email-delivery service required
PROJECTREADY_RECOVERY_PBKDF2_ITERATIONS=150000
PROJECTREADY_RECOVERY_WINDOW_SECONDS=900
PROJECTREADY_RECOVERY_MAX_ATTEMPTS=6
PROJECTREADY_ADMIN_KEY=

# Revision-only prices for chapters brought from outside ProjectReady AI
PROJECTREADY_BACHELORS_REVISION_USD=2.99
PROJECTREADY_MASTERS_REVISION_USD=5.99
PROJECTREADY_DOCTORATE_REVISION_USD=11.99
PROJECTREADY_PAYSTACK_BACHELORS_REVISION_GHS=
PROJECTREADY_PAYSTACK_MASTERS_REVISION_GHS=
PROJECTREADY_PAYSTACK_DOCTORATE_REVISION_GHS=
