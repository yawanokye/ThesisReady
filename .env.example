# Core application
APP_NAME=ProjectReady AI
APP_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=32000
OPENAI_MAX_OUTPUT_TOKENS_HARD_CAP=64000
OPENAI_SAFE_RETRY_MAX_OUTPUT_TOKENS=12000
PROJECTREADY_WORDS_PER_PAGE=330
PROJECTREADY_CHUNKED_GENERATION_THRESHOLD_WORDS=4500
PROJECTREADY_CHUNK_TARGET_WORDS=2200
PROJECTREADY_MAX_CHAPTER_CHUNKS=16
PROJECTREADY_DEPTH_ACCEPTANCE_RATIO=0.90

# Protected scholarly humanizer
# light = deterministic local refinement only
# balanced = local refinement plus one model pass only when diagnostics require it
# deep = local refinement plus one preservation-gated model pass
# off = no humanizer
PROJECTREADY_HUMANIZER_MODE=balanced
PROJECTREADY_HUMANIZER_PERPLEXITY_LEVEL=high
PROJECTREADY_HUMANIZER_BURSTINESS_LEVEL=high
PROJECTREADY_HUMANIZER_MAX_WORD_CHANGE_RATIO=0.06
PROJECTREADY_HUMANIZER_MODEL_THRESHOLD=97
PROJECTREADY_HUMANIZER_BATCH_WORDS=1800
PROJECTREADY_HUMANIZER_MAX_BATCHES_BALANCED=6
PROJECTREADY_HUMANIZER_MAX_BATCHES_DEEP=16
PROJECTREADY_ENABLE_GROQ_HUMANIZER=0

# Database storage
# Local development can use SQLite. A separate production web service and background
# worker MUST share the same PostgreSQL DATABASE_URL. Do not use separate local SQLite
# files for a commercial multi-service deployment.
DATABASE_URL=
PROJECTREADY_SQLITE_DB_PATH=projectready.db
PROJECTREADY_SQLITE_PAYMENT_DB=projectready.db

# Durable background processing
PROJECTREADY_BACKGROUND_JOBS_ENABLED=1
PROJECTREADY_JOB_MAX_ATTEMPTS=2
PROJECTREADY_WORKER_POLL_SECONDS=2
PROJECTREADY_WORKER_LEASE_SECONDS=2700
PROJECTREADY_WORKER_HEARTBEAT_SECONDS=90
# Optional stable worker name. Leave blank to use hostname and process ID.
PROJECTREADY_WORKER_ID=

# Payment redirects
PROJECTREADY_PAYMENT_SUCCESS_PATH=/workspace
PROJECTREADY_PAYMENT_CANCEL_PATH=/workspace

# Paystack for African billing countries
PAYSTACK_SECRET_KEY=sk_live_replace_me
PROJECTREADY_PAYSTACK_BACHELORS_GHS=
PROJECTREADY_PAYSTACK_MASTERS_GHS=
PROJECTREADY_PAYSTACK_DOCTORATE_GHS=
PROJECTREADY_PAYSTACK_USD_TO_GHS_RATE=15.00
PAYSTACK_USER_AGENT=ProjectReadyAI/1.0 (+https://projectreadyai.com; payments@projectreadyai.com)

# Stripe live payments for non-African billing countries
STRIPE_LIVE_SECRET_KEY=sk_live_replace_me
STRIPE_LIVE_WEBHOOK_SECRET=whsec_live_replace_me

# Legacy fallback variables remain supported but live-specific variables above are preferred.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Topic-idea data and instrument discovery
TOPIC_RESOURCE_SEARCH_TIMEOUT_SECONDS=10
TOPIC_DATASET_RESULTS=6
TOPIC_INSTRUMENT_RESULTS=6
TOPIC_SPECIFIC_RESOURCE_RESULTS=4
TOPIC_DATASET_MIN_RELEVANCE=5
TOPIC_INSTRUMENT_MIN_RELEVANCE=14


# Integrated Chapter Strengthener
PROJECTREADY_CHAPTER_REVISION_USE_AI=1
PROJECTREADY_CHAPTER_REVISION_TIMEOUT_SECONDS=900
PROJECTREADY_CHAPTER_REVISION_MAX_OUTPUT_TOKENS=18000
OPENAI_CHAPTER_REVISION_MODEL=gpt-5.5
OPENAI_CHAPTER_REVISION_BACHELOR_MODEL=gpt-5.4
OPENAI_CHAPTER_REVISION_MASTERS_MODEL=gpt-5.4
OPENAI_CHAPTER_REVISION_RESEARCH_MODEL=gpt-5.5
OPENAI_CHAPTER_REVISION_DOCTORAL_MODEL=gpt-5.5
OPENAI_CHAPTER_REVISION_FALLBACK_MODEL=gpt-5.4
PROJECTREADY_CHAPTER_REVISION_MODEL_ATTEMPTS=2
PROJECTREADY_MAX_UPLOAD_BYTES=15728640
PROJECTREADY_MAX_EXTRACTED_CHARS=120000

# Project ID recovery, no email-delivery service required
PROJECTREADY_RECOVERY_PBKDF2_ITERATIONS=150000
PROJECTREADY_RECOVERY_WINDOW_SECONDS=900
PROJECTREADY_RECOVERY_MAX_ATTEMPTS=6
PROJECTREADY_ADMIN_KEY=

# Revision-only prices for chapters brought from outside ProjectReady AI
PROJECTREADY_BACHELORS_REVISION_USD=2.99
PROJECTREADY_MASTERS_REVISION_USD=5.99
PROJECTREADY_DOCTORATE_REVISION_USD=11.99
PROJECTREADY_PAYSTACK_BACHELORS_REVISION_GHS=
PROJECTREADY_PAYSTACK_MASTERS_REVISION_GHS=
PROJECTREADY_PAYSTACK_DOCTORATE_REVISION_GHS=


# Topic Ideas one-time access
# Ghana is charged through Paystack. Other countries are charged through Stripe.
PROJECTREADY_TOPIC_IDEAS_USD=1.50
PROJECTREADY_PAYSTACK_TOPIC_IDEAS_GHS=10.00
# Private support key for the all-payment recovery dashboard. Use at least 16 random characters.
PROJECTREADY_SUPPORT_RECOVERY_KEY=

# Restricted internal operations portal, not public trial access
# The portal is not linked from public pages and requires BOTH an allow-listed email
# and a six-digit key. Use a private, hard-to-guess path and never publish it.
PROJECTREADY_INTERNAL_PORTAL_PATH=/internal/replace-with-a-private-random-operations-path
PROJECTREADY_INTERNAL_ACCESS_EMAILS=developer@example.com
# Production recommendation: leave the plain key blank and set its SHA-256 hash.
PROJECTREADY_INTERNAL_ACCESS_KEY=
# Generate with: python -c "import hashlib; print(hashlib.sha256(b'654321').hexdigest())"
PROJECTREADY_INTERNAL_ACCESS_KEY_SHA256=
PROJECTREADY_INTERNAL_ACCESS_SIGNING_SECRET=replace-with-at-least-32-random-characters
PROJECTREADY_INTERNAL_ACCESS_HOURS=12
PROJECTREADY_INTERNAL_LOGIN_MAX_ATTEMPTS=5
PROJECTREADY_INTERNAL_LOGIN_WINDOW_MINUTES=15
PROJECTREADY_COOKIE_SECURE=1
PROJECTREADY_ENABLE_LEGACY_INTERNAL_ACCESS_ENDPOINT=0
PROJECTREADY_EXPOSE_API_DOCS=0
# Same-origin deployments can leave this blank. Add comma-separated trusted origins only when required.
PROJECTREADY_ALLOWED_ORIGINS=
