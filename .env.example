# Core application
APP_NAME=ProjectReady AI
APP_BASE_URL=http://localhost:8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Local development: leave DATABASE_URL blank and use this SQLite file.
DATABASE_URL=
PROJECTREADY_SQLITE_DB_PATH=projectready.db
PROJECTREADY_SQLITE_PAYMENT_DB=projectready.db

# Payment redirects
PROJECTREADY_PAYMENT_SUCCESS_PATH=/workspace
PROJECTREADY_PAYMENT_CANCEL_PATH=/workspace

# Paystack for African billing countries
PAYSTACK_SECRET_KEY=sk_test_replace_me
PROJECTREADY_PAYSTACK_BACHELORS_GHS=
PROJECTREADY_PAYSTACK_MASTERS_GHS=
PROJECTREADY_PAYSTACK_DOCTORATE_GHS=
PROJECTREADY_PAYSTACK_USD_TO_GHS_RATE=15.00
PAYSTACK_USER_AGENT=ProjectReadyAI/1.0 (+https://projectreadyai.com; payments@projectreadyai.com)

# Stripe for non-African billing countries
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
