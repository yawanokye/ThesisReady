# The worker shares the same PostgreSQL database and OpenAI routing as the web service.
DATABASE_URL=
OPENAI_API_KEY=

OPENAI_MODEL=gpt-5.6-terra
OPENAI_FALLBACK_MODEL=gpt-5.6-luna
OPENAI_MAX_OUTPUT_TOKENS=32000
OPENAI_MAX_OUTPUT_TOKENS_HARD_CAP=64000
OPENAI_SAFE_RETRY_MAX_OUTPUT_TOKENS=12000
OPENAI_TOPIC_IDEA_TIMEOUT_SECONDS=180

PROJECTREADY_MODEL_ROUTING=level_based
PROJECTREADY_REVISION_ROUTING=same_as_draft
OPENAI_BACHELOR_DRAFT_MODEL=gpt-5.6-terra
OPENAI_BACHELOR_CORE_MODEL=gpt-5.6-terra
OPENAI_NONRESEARCH_MASTERS_DRAFT_MODEL=gpt-5.6-terra
OPENAI_NONRESEARCH_MASTERS_CORE_MODEL=gpt-5.6-terra
OPENAI_RESEARCH_MASTERS_DRAFT_MODEL=gpt-5.6-terra
OPENAI_DOCTORAL_DRAFT_MODEL=gpt-5.6-sol
OPENAI_SUPPLEMENTARY_GUIDE_MODEL=gpt-5.6-luna
OPENAI_REVISION_MODEL=gpt-5.6-terra
OPENAI_REVIEW_MODEL=gpt-5.6-sol
OPENAI_HUMANIZER_MODEL=gpt-5.6-terra
OPENAI_SECTION_ANALYSIS_MODEL=gpt-5.6-luna
OPENAI_FINAL_SYNTHESIS_MODEL=gpt-5.6-sol

PROJECTREADY_TOPIC_IDEA_PROVIDER=openai
PROJECTREADY_TOPIC_IDEAS_USE_AI=1
PROJECTREADY_TOPIC_TREND_SOURCE_LIMIT=24
PROJECTREADY_TOPIC_TREND_SEARCH_LIMIT=36
OPENAI_TOPIC_IDEA_MODEL=gpt-5.6-luna
OPENAI_TOPIC_IDEA_RESEARCH_MODEL=gpt-5.6-terra
OPENAI_TOPIC_IDEA_DOCTORAL_MODEL=gpt-5.6-terra

PROJECTREADY_WORDS_PER_PAGE=330
PROJECTREADY_CHUNKED_GENERATION_THRESHOLD_WORDS=4500
PROJECTREADY_CHUNK_TARGET_WORDS=2200
PROJECTREADY_MAX_CHAPTER_CHUNKS=16

# Automatic scholarly evidence support
PROJECTREADY_AUTO_SOURCE_SUPPORT=1
PROJECTREADY_AUTO_SOURCE_QUERY_COUNT=2
PROJECTREADY_AUTO_SOURCE_RESULTS_PER_QUERY=14
PROJECTREADY_AUTO_SOURCE_MINIMUM_OVERRIDE=0
PROJECTREADY_LONG_CHAPTER_THRESHOLD_WORDS=12000
PROJECTREADY_LONG_CHAPTER_UNIT_TARGET_WORDS=2500
PROJECTREADY_DEPTH_ACCEPTANCE_RATIO=0.90
PROJECTREADY_MAX_UPLOAD_BYTES=15728640
PROJECTREADY_MAX_EXTRACTED_CHARS=720000

PROJECTREADY_HUMANIZER_MODE=balanced
PROJECTREADY_HUMANIZER_PERPLEXITY_LEVEL=high
PROJECTREADY_HUMANIZER_BURSTINESS_LEVEL=high
PROJECTREADY_HUMANIZER_MAX_WORD_CHANGE_RATIO=0.06
PROJECTREADY_HUMANIZER_MODEL_THRESHOLD=94
PROJECTREADY_HUMANIZER_BATCH_WORDS=1800
PROJECTREADY_HUMANIZER_MAX_BATCHES_BALANCED=4
PROJECTREADY_HUMANIZER_MAX_BATCHES_DEEP=12
PROJECTREADY_ENABLE_GROQ_HUMANIZER=0

PROJECTREADY_CHAPTER_REVISION_USE_AI=1
PROJECTREADY_CHAPTER_REVISION_TIMEOUT_SECONDS=900
PROJECTREADY_CHAPTER_REVISION_MAX_OUTPUT_TOKENS=18000
PROJECTREADY_CHAPTER_REVISION_MODEL_ATTEMPTS=2
OPENAI_CHAPTER_REVISION_MODEL=gpt-5.6-terra
OPENAI_CHAPTER_REVISION_BACHELOR_MODEL=gpt-5.6-terra
OPENAI_CHAPTER_REVISION_MASTERS_MODEL=gpt-5.6-terra
OPENAI_CHAPTER_REVISION_RESEARCH_MODEL=gpt-5.6-terra
OPENAI_CHAPTER_REVISION_DOCTORAL_MODEL=gpt-5.6-sol
OPENAI_CHAPTER_REVISION_FALLBACK_MODEL=gpt-5.6-terra

PROJECTREADY_BACKGROUND_JOBS_ENABLED=1
PROJECTREADY_JOB_MAX_ATTEMPTS=2
PROJECTREADY_WORKER_POLL_SECONDS=2
PROJECTREADY_WORKER_LEASE_SECONDS=7200
PROJECTREADY_WORKER_HEARTBEAT_SECONDS=90
PROJECTREADY_WORKER_ID=projectready-worker-1

OPENALEX_MAILTO=
CROSSREF_MAILTO=
TOPIC_RESOURCE_SEARCH_TIMEOUT_SECONDS=10
TOPIC_DATASET_RESULTS=6
TOPIC_INSTRUMENT_RESULTS=6
TOPIC_SPECIFIC_RESOURCE_RESULTS=4
TOPIC_DATASET_MIN_RELEVANCE=22
TOPIC_INSTRUMENT_MIN_RELEVANCE=18
